@page
@model ClientsIndexModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Clients";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            @if (Model.Clients.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-light">
                            <tr>
                                <th></th>
                                <th>
                                    <a asp-page="/Clients/Index" 
                                       asp-route-sortColumn="ClientName" 
                                       asp-route-sortDirection="@(Model.SortColumn == "ClientName" && Model.SortDirection == "ASC" ? "DESC" : "ASC")"
                                       class="text-decoration-none">
                                        Client @(Model.SortColumn == "ClientName" ? (Model.SortDirection == "ASC" ? "↑" : "↓") : "↕")
                                    </a>
                                </th>
                                <th>
                                    <a asp-page="/Clients/Index" 
                                       asp-route-sortColumn="PrimaryContactLastName" 
                                       asp-route-sortDirection="@(Model.SortColumn == "PrimaryContactLastName" && Model.SortDirection == "ASC" ? "DESC" : "ASC")"
                                       class="text-decoration-none">
                                        Primary Contact @(Model.SortColumn == "PrimaryContactLastName" ? (Model.SortDirection == "ASC" ? "↑" : "↓") : "↕")
                                    </a>
                                </th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in Model.Clients)
                            {
                                <tr>
                                    <td>@c.ClientKey</td>
                                    <td>@c.ClientName</td>
                                    <td>@c.PrimaryContactName</td>
                                    <td>
                                        <a asp-page="/Clients/Client" 
                                           asp-route-clientKey="@c.ClientKey" 
                                           class="btn btn-sm btn-outline-primary">
                                            View Client
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info" role="alert">
                    No clients found.
                </div>
            }
        </div>
    </div>
</div>
