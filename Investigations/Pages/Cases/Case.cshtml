@page "/Cases/{caseKey:int}"
@model CaseModel
@{
    Layout = "_Layout";
    ViewData["Title"] = $"#{Model.Case.CaseNumber}";
}

<div class="container-fluid">
    <div class="row mb-3">
        <div class="col">
            <a asp-page="/Cases/Index" class="btn btn-outline-secondary btn-sm">
                &larr; Back to Cases
            </a>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col">
            <h2 class="mb-1">Case #@Model.Case.CaseNumber</h2>
            <span class="badge @(Model.Case.IsActive ? "bg-success" : "bg-secondary")">
                @Model.Case.Status
            </span>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-12 mb-3">
            <h5 class="text-muted border-bottom pb-2">Overview</h5>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-header">Subject</div>
                <div class="card-body">
                    <p class="card-text mb-0"><strong>@Model.Case.SubjectName</strong>
                    </p>
                    <p class="card-text text-muted small">Key: @Model.Case.SubjectKey</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-header">Client</div>
                <div class="card-body">
                    <p class="card-text mb-0"><strong>@Model.Case.ClientName</strong></p>
                    <p class="card-text text-muted small">Key: @Model.Case.ClientKey</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-header">Case Type</div>
                <div class="card-body">
                    <p class="card-text mb-0"><strong>@Model.Case.CaseTypeCode</strong></p>
                    <p class="card-text text-muted small">@Model.Case.CaseTypeDescription</p>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Case.DateOfReferral))
    {
        <div class="row mb-4">
            <div class="col-12">
                <p class="mb-1"><strong>Date Referred:</strong> @Model.Case.DateOfReferral</p>
            </div>
        </div>
    }

    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>Synopsis</span>
                    <button class="btn btn-outline-primary btn-sm" disabled>Edit Synopsis</button>
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrWhiteSpace(Model.Case.Synopsis))
                    {
                        <p class="card-text">@Model.Case.Synopsis</p>
                    }
                    else
                    {
                        <p class="card-text text-muted fst-italic">No synopsis provided.</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>Contacts</span>
                    <button class="btn btn-outline-primary btn-sm" disabled>Add Contact</button>
                </div>
                <div class="card-body">
                    <p class="card-text text-muted fst-italic">Coming soon...</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>Tasks</span>
                    <a asp-page="/Tasks/Create" asp-route-SourcedCaseKey="@Model.CaseKey"
                       class="btn btn-outline-primary btn-sm">+ Add Task</a>
                </div>
                <div class="card-body">
                    @foreach (var task in Model.Tasks)
                    {
                        var id = $"task-checkbox-{task.TaskKey}";

                        <div class="mb-3 p-3 border rounded d-flex align-items-start gap-3">

                            <input type="checkbox" id="@id" data-taskKey="@task.TaskKey" data-caseKey="@Model.CaseKey"
                                   class="form-check-input mt-1 task-checkbox" @(task.IsCompleted ? "checked" : "") />

                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between align-items-center">
                                    <h6 class="mb-1 @(task.IsCompleted ? "text-decoration-line-through text-muted" : "")">
                                        @task.TaskName
                                    </h6>
                                    <small class="text-muted">Due: @task.DueDate</small>
                                </div>

                                <p class="mb-2 text-muted">
                                    @task.TaskDescription
                                </p>

                                <small class="text-muted">
                                    Assigned to:
                                    <a asp-page="/Account/Profile" asp-route-userKey="@(task.AssignedToUserKey)">
                                        @task.AssignedToUser
                                    </a>
                                </small>
                            </div>

                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <hr />
            <p class="text-muted small mb-0">
                <strong>Created by:</strong> <a asp-page="/Account/Profile"
                                                asp-route-userKey=@Model.Case.InsertedByUserKey>@Model.Case.InsertedByUser</a>
                on @Model.Case.InsertedOnDateTime
            </p>
            @if (!string.IsNullOrEmpty(Model.Case.UpdatedOnDateTime))
            {
                <p class="text-muted small mb-0">
                    <strong>Updated by:</strong> <a asp-page="/Account/Profile"
                                                    asp-route-userKey=@Model.Case.UpdatedByUserKey>@Model.Case.UpdatedByUser</a>
                    on @Model.Case.UpdatedOnDateTime
                </p>
            }
        </div>
    </div>
</div>
</div>

@section Scripts {
    <script type="text/javascript" src="@Url.Content("/Pages/Cases/Case.cshtml.js")"></script>
}
